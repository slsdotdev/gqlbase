{
  "name": "@gqlbase/core",
  "description": "Core library for gqlbase, providing the GraphQL transformer and plugin system.",
  "version": "0.1.0",
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "sls.dev",
    "email": "dev@sls.dev",
    "url": "https://wwww.sls.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.sls.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slsdotdev/gqlbase.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/slsdotdev/gqlbase/issues"
  },
  "files": [
    "dist",
    "README.md",
    "../../LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "default": "./dist/*/index.js",
      "types": "./dist/*/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@gqlbase/shared": "^0.1.0"
  },
  "peerDependencies": {
    "graphql": "^16.13.2"
  }
}
