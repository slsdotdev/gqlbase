{
  "name": "@gqlbase/cli",
  "description": "Command-line interface for gqlbase, providing tools for schema transformation and development workflow",
  "version": "0.0.7",
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "sls.dev",
    "email": "dev@sls.dev",
    "url": "https://wwww.sls.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.sls.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slsdotdev/gqlbase.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/slsdotdev/gqlbase/issues"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "../../LICENSE"
  ],
  "bin": {
    "gqlbase": "./bin/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "default": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@gqlbase/core": "^0.0.7",
    "@gqlbase/shared": "^0.0.7",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@gqlbase/plugins": "^0.0.7"
  }
}
