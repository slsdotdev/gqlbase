{
  "name": "gqlbase",
  "description": "A modular GraphQL schema transformation framework that allows developers to define and apply a series of transformations to their GraphQL schemas in a flexible and composable manner.",
  "version": "0.0.8",
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "sls.dev",
    "email": "dev@sls.dev",
    "url": "https://wwww.sls.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.sls.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slsdotdev/gqlbase.git",
    "directory": "packages/gqlbase"
  },
  "bugs": {
    "url": "https://github.com/slsdotdev/gqlbase/issues"
  },
  "keywords": [
    "GraphQL"
  ],
  "files": [
    "dist",
    "README.md",
    "../../LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": {
      "default": "./dist/*/index.js",
      "types": "./dist/*/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix"
  },
  "dependencies": {
    "@gqlbase/cli": "^0.0.8",
    "@gqlbase/core": "^0.0.8",
    "@gqlbase/plugins": "^0.0.8",
    "@gqlbase/shared": "^0.0.8"
  }
}
